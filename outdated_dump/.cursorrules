# DogeTech Project Structure Rules
# This defines how Cursor should interpret and navigate the project structure

# Project Root
[/]
description = "DogeTech - A Solana-based mining game with DogeBtc token economy"
tags = ["solana", "moonDoge", "lunar-mining", "play-to-earn"]

# Game Logic - Solana Programs
[/gameLogic/]
description = "Solana programs (smart contracts) implementing game mechanics"

[/gameLogic/moonFacility/]
description = "Moon Facility program - Handles moon base, modules, mining gear, and rewards"
language = "rust"
type = "anchor-program"
tags = ["moonbase", "mining-modules", "doge-nfts"]

[/gameLogic/moonEconomy/]
description = "Moon Economy program - Handles token economics and marketplace"
language = "rust"
type = "anchor-program"
tags = ["token-economy", "marketplace", "mdoge-token"]

# Deployment Scripts
[/deploy/]
description = "Scripts for deploying DogeBtc token and initializing the economy"
language = "javascript"

[/deploy/config/]
description = "Configuration files for deployment"

# Initialization Scripts
[/scripts/]
description = "Scripts for initializing and configuring the Solana programs"
language = "javascript"

[/scripts/config/]
description = "Configuration files for program initialization including keypairs and IDL"

# Frontend Application
[/websiteApp/]
description = "Next.js web application for interacting with the Solana programs"
language = "typescript"
framework = "next.js"

[/websiteApp/src/]
description = "Source code for the frontend application"

[/websiteApp/src/app/]
description = "Next.js app router pages and layouts"
tags = ["lunar-ui", "space-theme"]

[/websiteApp/src/components/]
description = "Reusable UI components for moonbase, mining operations, and doge management"
tags = ["moon-panels", "mining-ui", "doge-interfaces"]

[/websiteApp/src/utils/]
description = "Utility functions for the frontend"

[/websiteApp/src/hooks/]
description = "React hooks for Solana wallet and program interactions"
tags = ["solana-hooks", "mdoge-mining"]

[/websiteApp/src/context/]
description = "React context providers for state management"

[/websiteApp/src/redux/]
description = "Redux state management for game state including mining operations"
tags = ["mining-state", "moonbase-management"]

# Dependencies and Build
[node_modules/]
ignore = true

[.next/]
ignore = true

# Patterns
[*.json]
type = "config"

[*.js]
language = "javascript"

[*.ts]
language = "typescript"

[*.tsx]
language = "typescript"
type = "react-component"

# Rust Program Files
[*.rs]
language = "rust"

# Solana/Anchor specific
[Anchor.toml]
type = "config"
description = "Anchor framework configuration for Solana programs"

[Cargo.toml]
type = "config"
description = "Rust package configuration for Solana programs"

# Game Component Types
[NFT]
description = "Doge NFT components that boost mining operations"
tags = ["astronaut-doge", "miner-doge", "engineer-doge"]

[Module]
description = "Facility modules like mining rooms and power plants"
tags = ["mining-room", "power-plant", "control-center"]

[Gear]
description = "Mining equipment and utility gear for moonbase"
tags = ["mining-rig", "power-generator", "doge-habitat"]

# Game Logic Relationships
[[relationship]]
name = "implements"
from = "/gameLogic/moonFacility/"
to = "/scripts/initialize-program.js"
description = "Scripts initialize the Moon Facility program"

[[relationship]]
name = "interacts_with"
from = "/websiteApp/src/hooks/"
to = "/gameLogic/moonFacility/"
description = "Frontend hooks interact with the Moon Facility program"

[[relationship]]
name = "deploys"
from = "/deploy/1_mint_moondoge.js"
to = "/gameLogic/moonEconomy/"
description = "Deployment script creates the DogeBtc token used by the economy"

[[relationship]]
name = "boosts"
from = "NFT"
to = "Module"
description = "Doge NFTs boost the efficiency of modules they're assigned to"

[[relationship]]
name = "powers"
from = "Module"
to = "Gear"
description = "Modules provide space and power for mining gear"

[[relationship]]
name = "generates"
from = "Gear"
to = "DogeBtc"
description = "Mining gear generates DogeBtc tokens based on hashpower"
