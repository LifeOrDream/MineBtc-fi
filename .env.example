# Copy to .env and fill in real values. .env is gitignored.
#
# Helius API key — used by setup_scripts/*.js as the RPC provider for both
# devnet and mainnet, and by do_txs.js for Helius enhanced endpoints
# (withheld-fees harvest discovery, etc).
#
# Get one at https://dashboard.helius.dev/api-keys
#
# The same key works for devnet + mainnet on Helius. If you want separate
# keys per cluster, you can wrap your shell session and export different
# values when running devnet vs mainnet scripts.
HELIUS_API_KEY=

# Optional — used in tests / localnet only. Override if you want devnet
# scripts to use a non-Helius RPC.
# DEVNET_RPC_URL=

# Optional — override the mainnet RPC entirely (bypasses Helius).
# MAINNET_RPC_URL=
