# Copy to .env and fill in real values. .env is gitignored.
#
# Optional Helius API key for local RPC tooling or private operational
# automation. Never commit real keys; keep filled values in your local .env.
#
# Get one at https://dashboard.helius.dev/api-keys
#
# The same key works for devnet + mainnet on Helius. If you want separate keys
# per cluster, export different values in your shell session.
HELIUS_API_KEY=

# Optional local RPC overrides.
# DEVNET_RPC_URL=

# Optional — override the mainnet RPC entirely (bypasses Helius).
# MAINNET_RPC_URL=
